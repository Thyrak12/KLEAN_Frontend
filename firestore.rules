rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function role() {
      return isSignedIn() && userDoc().exists() ? userDoc().data.role : null;
    }

    function isSuperAdmin() {
      return role() == 'super_admin';
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    match /users/{userId} {
      // TEMP DEV RULES for admin dashboard testing.
      // Any signed-in user can read/write user profiles.
      // Tighten after testing.
      allow read, create, update: if isSignedIn();
      allow delete: if isSuperAdmin();
    }

    match /restaurants/{restaurantId} {
      allow read: if isSignedIn();
      allow create: if isOwner(restaurantId) || isSuperAdmin();
      allow update: if isOwner(restaurantId) || isSuperAdmin();
      allow delete: if isSuperAdmin();
    }

    match /restaurantRequests/{requestId} {
      // TEMP DEV RULES for seeding:
      // Any signed-in user can create/read/write restaurant requests.
      // Tighten this after seeding is complete.
      allow read, create, update, delete: if isSignedIn();
    }
  }
}
