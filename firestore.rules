rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function for privileged admin role via custom claims.
    function isAdminFromToken() {
      return request.auth != null && (
        request.auth.token.role == 'super_admin' ||
        request.auth.token.role == 'admin' ||
        request.auth.token.admin == true
      );
    }

    // Fallback for existing apps that store role in /users/{uid}.
    function isAdminFromProfile() {
      return request.auth != null
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && (
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'super_admin' ||
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
        );
    }

    function isAdminUser() {
      return isAdminFromToken() || isAdminFromProfile();
    }

    // Chats: each user can only read/write their own messages. Admin users may access all chats.
    match /chats/{uid}/messages/{messageId} {
      allow read, write: if request.auth != null && (request.auth.uid == uid || isAdminUser());
    }

    // Restaurants: anyone authenticated can read; owner or admin can write.
    match /restaurants/{restaurantId} {
      allow read: if request.auth != null;
      // Allow admin to create/edit on behalf of the owner
      allow create: if request.auth != null && (request.auth.uid == request.resource.data.uid || isAdminUser());
      allow update, delete: if request.auth != null && (request.auth.uid == resource.data.uid || isAdminUser());

      // Menus & Reviews subcollections
      match /menus/{menuId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null
          && (request.auth.uid == get(/databases/$(database)/documents/restaurants/$(restaurantId)).data.uid || isAdminUser());

        match /reviews/{reviewId} {
          allow read: if request.auth != null;
          allow create: if request.auth != null;
          allow update, delete: if request.auth != null
            && (
              (resource.data.userId is string && request.auth.uid == resource.data.userId) ||
              (resource.data.user_id is string && request.auth.uid == resource.data.user_id) || 
              isAdminUser()
            );
        }
      }

      match /menu_items/{menuId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null
          && (request.auth.uid == get(/databases/$(database)/documents/restaurants/$(restaurantId)).data.uid || isAdminUser());

        match /reviews/{reviewId} {
          allow read: if request.auth != null;
          allow create: if request.auth != null;
          allow update, delete: if request.auth != null
            && (
              (resource.data.userId is string && request.auth.uid == resource.data.userId) ||
              (resource.data.user_id is string && request.auth.uid == resource.data.user_id) ||
              isAdminUser()
            );
        }
      }

      match /reviews/{reviewId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null;
        allow update, delete: if request.auth != null
          && (
            (resource.data.userId is string && request.auth.uid == resource.data.userId) ||
            (resource.data.user_id is string && request.auth.uid == resource.data.user_id) ||
            isAdminUser()
          );
      }

      // Promotions
      match /promotions/{promotionId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null
          && (request.auth.uid == get(/databases/$(database)/documents/restaurants/$(restaurantId)).data.uid || isAdminUser());
      }
    }

    // User profiles: users can access their own; super admins can access/modify all.
    // Only super admins can list all users.
    match /users/{userId} {
      allow get: if request.auth != null && (request.auth.uid == userId || isAdminUser());
      allow list: if request.auth != null && isAdminUser();
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update, delete: if request.auth != null && (request.auth.uid == userId || isAdminUser());
    }

    // Restaurant Requests
    match /restaurantRequests/{requestId} {
      // Single document access: owner or super admin
      allow get: if request.auth != null && (
        resource.data.ownerId == request.auth.uid ||
        resource.data.uid == request.auth.uid ||
        isAdminUser()
      );

      // Listing: super admins can list all. Owners can list only their own documents.
      allow list: if request.auth != null && (
        isAdminUser() ||
        resource.data.ownerId == request.auth.uid ||
        resource.data.uid == request.auth.uid
      );

      // Owner creates own request
      allow create: if request.auth != null && (
        request.resource.data.ownerId == request.auth.uid ||
        request.resource.data.uid == request.auth.uid ||
        isAdminUser()
      );

      // Super Admins can update/approve, owner can update before approval
      allow update: if request.auth != null && (
        (request.resource.data.ownerId == request.auth.uid || request.resource.data.uid == request.auth.uid) ||
        isAdminUser()
      );

      allow delete: if isAdminUser();
    }

    match /{document=**} {
      allow read, write: if false;
    }

  }
}