rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if the current user is a super admin
    function isSuperAdmin() {
      return request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'super_admin';
    }

    // Chats: each user can only read/write their own messages.
    match /chats/{uid}/messages/{messageId} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Restaurants: anyone authenticated can read; owner or super admin can write.
    match /restaurants/{restaurantId} {
      allow read: if request.auth != null;
      // Allow super_admin to create/edit on behalf of the owner
      allow create: if request.auth != null && (request.auth.uid == request.resource.data.uid || isSuperAdmin());
      allow update, delete: if request.auth != null && (request.auth.uid == resource.data.uid || isSuperAdmin());

      // Menus & Reviews subcollections
      match /menus/{menuId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null
          && (request.auth.uid == get(/databases/$(database)/documents/restaurants/$(restaurantId)).data.uid || isSuperAdmin());

        match /reviews/{reviewId} {
          allow read: if request.auth != null;
          allow create: if request.auth != null;
          allow update, delete: if request.auth != null
            && (
              (resource.data.userId is string && request.auth.uid == resource.data.userId) ||
              (resource.data.user_id is string && request.auth.uid == resource.data.user_id) || 
              isSuperAdmin()
            );
        }
      }

      match /menu_items/{menuId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null
          && (request.auth.uid == get(/databases/$(database)/documents/restaurants/$(restaurantId)).data.uid || isSuperAdmin());

        match /reviews/{reviewId} {
          allow read: if request.auth != null;
          allow create: if request.auth != null;
          allow update, delete: if request.auth != null
            && (
              (resource.data.userId is string && request.auth.uid == resource.data.userId) ||
              (resource.data.user_id is string && request.auth.uid == resource.data.user_id) ||
              isSuperAdmin()
            );
        }
      }

      match /reviews/{reviewId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null;
        allow update, delete: if request.auth != null
          && (
            (resource.data.userId is string && request.auth.uid == resource.data.userId) ||
            (resource.data.user_id is string && request.auth.uid == resource.data.user_id) ||
            isSuperAdmin()
          );
      }

      // Promotions
      match /promotions/{promotionId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null
          && (request.auth.uid == get(/databases/$(database)/documents/restaurants/$(restaurantId)).data.uid || isSuperAdmin());
      }
    }

    // User profiles: users can access their own; super admins can access/modify all.
    match /users/{userId} {
      allow read, write: if request.auth != null && (request.auth.uid == userId || isSuperAdmin());
    }

    // Restaurant Requests
    match /restaurantRequests/{requestId} {
      allow read: if request.auth != null && (
        resource.data.ownerId == request.auth.uid ||
        resource.data.uid == request.auth.uid ||
        isSuperAdmin()
      );

      // Owner creates own request
      allow create: if request.auth != null && (
        request.resource.data.ownerId == request.auth.uid ||
        request.resource.data.uid == request.auth.uid ||
        isSuperAdmin()
      );

      // Super Admins can update/approve, owner can ONLY update if you explicitly want them to edit prior to approval
      allow update: if request.auth != null && (
        (request.resource.data.ownerId == request.auth.uid || request.resource.data.uid == request.auth.uid) ||
        isSuperAdmin()
      );

      allow delete: if isSuperAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }

  }
}