rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function userDocPath() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    function role() {
      return isSignedIn() && exists(userDocPath()) ? get(userDocPath()).data.role : null;
    }

    function isSuperAdmin() {
      return role() == 'super_admin';
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isRestaurantOwner(restaurantId) {
      return isSignedIn() &&
        get(/databases/$(database)/documents/restaurants/$(restaurantId)).data.uid == request.auth.uid;
    }

    match /users/{userId} {
      // User can read own profile; super admin can read all
      allow read: if isOwner(userId) || isSuperAdmin();

      // User can create/update own profile; super admin can update any user role
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isSuperAdmin();
      allow delete: if isSuperAdmin();
    }

    match /restaurants/{restaurantId} {
      allow read: if isSignedIn();
      allow create: if (request.resource.data.uid == request.auth.uid) || isSuperAdmin();
      allow update: if isRestaurantOwner(restaurantId) || isSuperAdmin();
      allow delete: if isSuperAdmin();

      match /menu_items/{itemId} {
        allow read: if isSignedIn();
        allow create, update, delete: if isRestaurantOwner(restaurantId) || isSuperAdmin();
      }

      match /promotions/{promoId} {
        allow read: if isSignedIn();
        allow create, update, delete: if isRestaurantOwner(restaurantId) || isSuperAdmin();
      }

      match /reviews/{reviewId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn();
        allow update, delete: if isSignedIn() && (
          request.auth.uid == resource.data.userId ||
          isRestaurantOwner(restaurantId) ||
          isSuperAdmin()
        );
      }
    }

    match /restaurantRequests/{requestId} {
      // Owner can read own request; super admin can read all
      allow read: if isSignedIn() && (
        resource.data.ownerId == request.auth.uid ||
        resource.data.uid == request.auth.uid ||
        isSuperAdmin()
      );

      // Owner creates own request; super admin can create for testing/migration
      allow create: if isSignedIn() && (
        request.resource.data.ownerId == request.auth.uid ||
        request.resource.data.uid == request.auth.uid ||
        isSuperAdmin()
      );

      // Owner can update their own request (for resubmission); super admin can update any
      allow update: if isSignedIn() && (
        resource.data.ownerId == request.auth.uid ||
        resource.data.uid == request.auth.uid ||
        isSuperAdmin()
      );

      // Only super admin can delete
      allow delete: if isSuperAdmin();
    }

    match /chats/{uid}/messages/{messageId} {
      allow read, write: if isOwner(uid);
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
